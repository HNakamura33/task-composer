{
  "tasks": [
    {
      "task_id": "1",
      "name": "Fetch User Data",
      "description": "Fetch user information from API",
      "priority": 1,
      "status": "Pending",
      "prompt": "Fetch user data from the database",
      "executor": "log",
      "args": {
        "endpoint": "/api/users",
        "method": "GET"
      },
      "dependencies": [],
      "role": {
        "role_id": "role_api",
        "name": "API Role",
        "subagents": [],
        "skills": ["api"],
        "description": "Role for API tasks",
        "tool_permissions": {
          "bash": { "allowed_commands": [], "blocked_commands": [], "require_confirmation": [] },
          "write": { "max_file_size_mb": 10, "allowed_extensions": [] }
        },
        "file_permissions": { "allowed_paths": [], "denied_paths": [], "read_only_paths": [] }
      }
    },
    {
      "task_id": "2",
      "name": "Generate Report",
      "description": "Generate a report based on user data",
      "priority": 2,
      "status": "Pending",
      "prompt": "Create a summary report for the user",
      "executor": "log",
      "args": {
        "format": "markdown",
        "title": "User Report"
      },
      "inputs": {
        "previous_task_id": "$.1.output.task_id",
        "previous_message": "$.1.output.message",
        "summary": "Report based on: ${$.1.output.message}",
        "header": "Task: ${$.self.name} - ${$.self.description}"
      },
      "dependencies": ["1"],
      "role": {
        "role_id": "role_report",
        "name": "Report Role",
        "subagents": [],
        "skills": ["reporting"],
        "description": "Role for generating reports",
        "tool_permissions": {
          "bash": { "allowed_commands": [], "blocked_commands": [], "require_confirmation": [] },
          "write": { "max_file_size_mb": 10, "allowed_extensions": [".md", ".txt"] }
        },
        "file_permissions": { "allowed_paths": [], "denied_paths": [], "read_only_paths": [] }
      }
    },
    {
      "task_id": "3",
      "name": "Send Notification",
      "description": "Send notification to the user",
      "priority": 3,
      "status": "Pending",
      "prompt": "Notify the user about the generated report",
      "executor": "log",
      "args": {
        "channel": "email"
      },
      "inputs": {
        "task1_result": "$.1.output.message",
        "task2_result": "$.2.output.message",
        "combined": "Task1: ${$.1.output.message} | Task2: ${$.2.output.message}",
        "subject": "[${$.self.name}] Report Generated",
        "metadata": {
          "task_info": "Sent by: ${$.self.name} (priority: ${$.self.priority})",
          "source_task_id": "$.2.output.task_id",
          "my_prompt": "${$.self.prompt}"
        }
      },
      "dependencies": ["1", "2"],
      "role": {
        "role_id": "role_notify",
        "name": "Notification Role",
        "subagents": [],
        "skills": ["notification"],
        "description": "Role for sending notifications",
        "tool_permissions": {
          "bash": { "allowed_commands": [], "blocked_commands": [], "require_confirmation": [] },
          "write": { "max_file_size_mb": 1, "allowed_extensions": [] }
        },
        "file_permissions": { "allowed_paths": [], "denied_paths": [], "read_only_paths": [] }
      }
    }
  ]
}
