{
  "tasks": [
    {
      "task_id": "create_issue",
      "name": "Create Issue",
      "description": "Create a new issue",
      "executor": "github",
      "args": {
        "owner": "HNakamura33",
        "repo": "task-composer-test",
        "action": {
          "type": "create_issue",
          "title": "Test Issue - All Operations Demo",
          "body": "This issue demonstrates all GitHubExecutor operations."
        }
      }
    },
    {
      "task_id": "get_issue",
      "name": "Get Issue",
      "description": "Get issue details",
      "executor": "github",
      "args": {
        "owner": "HNakamura33",
        "repo": "task-composer-test",
        "action": {
          "type": "get_issue",
          "number": "$.create_issue.output.number"
        }
      },
      "dependencies": ["create_issue"]
    },
    {
      "task_id": "list_issues",
      "name": "List Issues",
      "description": "List all issues",
      "executor": "github",
      "args": {
        "owner": "HNakamura33",
        "repo": "task-composer-test",
        "action": {
          "type": "list_issues",
          "state": "all",
          "per_page": 10,
          "page": 1
        }
      }
    },
    {
      "task_id": "update_issue",
      "name": "Update Issue",
      "description": "Update issue title and body",
      "executor": "github",
      "args": {
        "owner": "HNakamura33",
        "repo": "task-composer-test",
        "action": {
          "type": "update_issue",
          "number": "$.create_issue.output.number",
          "title": "Test Issue - Updated Title",
          "body": "This issue has been updated by GitHubExecutor."
        }
      },
      "dependencies": ["create_issue", "get_issue"]
    },
    {
      "task_id": "create_comment",
      "name": "Create Comment",
      "description": "Add a comment to the issue",
      "executor": "github",
      "args": {
        "owner": "HNakamura33",
        "repo": "task-composer-test",
        "action": {
          "type": "create_comment",
          "number": "$.create_issue.output.number",
          "body": "This is a test comment added by GitHubExecutor."
        }
      },
      "dependencies": ["create_issue", "update_issue"]
    },
    {
      "task_id": "delete_comment",
      "name": "Delete Comment",
      "description": "Delete the comment",
      "executor": "github",
      "args": {
        "owner": "HNakamura33",
        "repo": "task-composer-test",
        "action": {
          "type": "delete_comment",
          "comment_id": "$.create_comment.output.id"
        }
      },
      "dependencies": ["create_comment"]
    },
    {
      "task_id": "close_issue",
      "name": "Close Issue",
      "description": "Close the issue",
      "executor": "github",
      "args": {
        "owner": "HNakamura33",
        "repo": "task-composer-test",
        "action": {
          "type": "close_issue",
          "number": "$.create_issue.output.number",
          "reason": "completed"
        }
      },
      "dependencies": ["create_issue", "delete_comment"]
    },
    {
      "task_id": "list_prs",
      "name": "List PRs",
      "description": "List all pull requests",
      "executor": "github",
      "args": {
        "owner": "HNakamura33",
        "repo": "task-composer-test",
        "action": {
          "type": "list_prs",
          "state": "all",
          "per_page": 10
        }
      }
    }
  ]
}
