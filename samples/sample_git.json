{
  "tasks": [
    {
      "task_id": "clone_repo",
      "name": "Clone Repository",
      "description": "Clone a repository from GitHub",
      "executor": "git",
      "args": {
        "action": {
          "type": "clone",
          "url": "https://github.com/example/repo.git",
          "path": "/tmp/my-repo",
          "branch": "main"
        }
      }
    },
    {
      "task_id": "check_status",
      "name": "Check Status",
      "description": "Check repository status after clone",
      "executor": "git",
      "args": {
        "action": {
          "type": "status",
          "path": "/tmp/my-repo",
          "include_untracked": true
        }
      },
      "dependencies": ["clone_repo"]
    },
    {
      "task_id": "create_branch",
      "name": "Create Feature Branch",
      "description": "Create and checkout a new feature branch",
      "executor": "git",
      "args": {
        "action": {
          "type": "create_branch",
          "path": "/tmp/my-repo",
          "name": "feature/new-feature",
          "checkout": true
        }
      },
      "dependencies": ["check_status"]
    },
    {
      "task_id": "commit_changes",
      "name": "Commit Changes",
      "description": "Commit all changes with a message",
      "executor": "git",
      "args": {
        "action": {
          "type": "commit",
          "path": "/tmp/my-repo",
          "message": "Add new feature",
          "add_all": true,
          "author_name": "Developer",
          "author_email": "dev@example.com"
        }
      },
      "dependencies": ["create_branch"]
    },
    {
      "task_id": "show_log",
      "name": "Show Commit Log",
      "description": "Display recent commit history",
      "executor": "git",
      "args": {
        "action": {
          "type": "log",
          "path": "/tmp/my-repo",
          "max_count": 5
        }
      },
      "dependencies": ["commit_changes"]
    }
  ]
}
